generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending
  paid
  failed
  refunded
  cancelled
}

enum LicenseStatus {
  active
  superseded
  revoked
  refund_revoked
  expired
}

enum WebhookStatus {
  received
  processed
  ignored
  error
}

enum MagicLinkPurpose {
  portal_access
  download_license
}

enum OrganizationMemberRole {
  owner
  admin
  member
}

enum OrganizationMemberStatus {
  active
  pending
  removed
}

enum SeatAssignmentStatus {
  active
  unassigned
  pending
}

enum ActivationStatus {
  requested
  confirmed
  revoked
  expired
}

model Customer {
  id                 String           @id @default(cuid())
  email              String           @unique
  name               String?
  externalCustomerId String?          @unique
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  orders             Order[]
  licenses           License[]
  webhookEvents      WebhookEvent[]
  magicLinkTokens    MagicLinkToken[]
  organizationsOwned Organization[]   @relation("OrganizationOwner")
  organizationMemberships OrganizationMember[] @relation("OrganizationMembership")
  seatAssignments    SeatAssignment[]
  activationRecords  ActivationRecord[]

  @@map("customers")
}

model Order {
  id              String         @id @default(cuid())
  externalOrderId String         @unique
  paymentProvider String
  status          OrderStatus    @default(pending)
  edition         String
  externalPaymentId String?
  externalSubscriptionId String?
  amountCents     Int?
  currency        String?
  paidAt          DateTime?
  failedAt        DateTime?
  refundedAt      DateTime?
  cancelledAt     DateTime?
  statusReason    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  customerId      String
  customer        Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  licenses        License[]
  webhookEvents   WebhookEvent[]
  systemActions   SystemAction[]

  @@index([externalPaymentId])
  @@index([externalSubscriptionId])
  @@index([customerId])
  @@map("orders")
}

model License {
  id                  String         @id @default(cuid())
  licenseId           String         @unique
  schemaVersion       Int
  keyId               String
  edition             String
  status              LicenseStatus  @default(active)
  subjectEmail        String
  issuedAt            DateTime
  notBefore           DateTime
  notAfter            DateTime
  revokedAt           DateTime?
  revokeReason        String?
  payloadJson         Json
  signedLicenseJson   Json
  signatureBase64     String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  customerId          String
  orderId             String
  supersedesLicenseId String?        @unique
  supersededAt        DateTime?
  customer            Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  order               Order          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  supersedesLicense   License?       @relation("LicenseSupersede", fields: [supersedesLicenseId], references: [id])
  supersededBy        License?       @relation("LicenseSupersede")
  webhookEvents       WebhookEvent[]
  adminActions        AdminAction[]
  systemActions       SystemAction[]
  seatEntitlements    SeatEntitlement[]
  activationRecords   ActivationRecord[]

  @@index([orderId, status])
  @@index([customerId, status])
  @@map("licenses")
}

model WebhookEvent {
  id              String        @id @default(cuid())
  provider        String
  eventId         String
  eventType       String
  status          WebhookStatus @default(received)
  payloadJson     Json
  processedAt     DateTime?
  errorMessage    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  customerId      String?
  orderId         String?
  licenseId       String?
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order           Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  license         License?      @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  systemActions   SystemAction[]

  @@unique([provider, eventId])
  @@index([orderId])
  @@index([licenseId])
  @@map("webhook_events")
}

model MagicLinkToken {
  id          String          @id @default(cuid())
  email       String
  tokenHash   String          @unique
  purpose     MagicLinkPurpose
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime        @default(now())
  customerId  String?
  customer    Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([customerId])
  @@map("magic_link_tokens")
}

model AdminAction {
  id          String    @id @default(cuid())
  actorEmail  String
  actionType  String
  targetType  String
  targetId    String
  payloadJson Json
  createdAt   DateTime  @default(now())
  licenseId   String?
  license     License?  @relation(fields: [licenseId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([licenseId])
  @@map("admin_actions")
}

model SystemAction {
  id             String       @id @default(cuid())
  source         String
  actionType     String
  targetType     String
  targetId       String
  payloadJson    Json
  createdAt      DateTime     @default(now())
  orderId        String?
  licenseId      String?
  webhookEventId String?
  order          Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  license        License?     @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  webhookEvent   WebhookEvent? @relation(fields: [webhookEventId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([orderId])
  @@index([licenseId])
  @@index([webhookEventId])
  @@map("system_actions")
}

model Organization {
  id              String               @id @default(cuid())
  slug            String               @unique
  name            String
  billingEmail    String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  ownerCustomerId String?
  ownerCustomer   Customer?            @relation("OrganizationOwner", fields: [ownerCustomerId], references: [id], onDelete: SetNull)
  members         OrganizationMember[]
  seatEntitlements SeatEntitlement[]
  seatAssignments SeatAssignment[]
  activationRecords ActivationRecord[]

  @@index([ownerCustomerId])
  @@map("organizations")
}

model OrganizationMember {
  id             String                   @id @default(cuid())
  organizationId String
  customerId     String?
  email          String
  role           OrganizationMemberRole   @default(member)
  status         OrganizationMemberStatus @default(active)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer?                @relation("OrganizationMembership", fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([organizationId, email])
  @@index([customerId])
  @@map("organization_members")
}

model SeatEntitlement {
  id             String            @id @default(cuid())
  organizationId String
  licenseId      String
  edition        String
  seatCount      Int               @default(1)
  activeFrom     DateTime          @default(now())
  activeUntil    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  license        License           @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  assignments    SeatAssignment[]

  @@unique([organizationId, licenseId])
  @@index([licenseId])
  @@map("seat_entitlements")
}

model SeatAssignment {
  id                String               @id @default(cuid())
  seatEntitlementId String
  organizationId    String
  customerId        String?
  email             String
  status            SeatAssignmentStatus @default(active)
  assignedByEmail   String?
  assignedAt        DateTime             @default(now())
  unassignedAt      DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  seatEntitlement   SeatEntitlement      @relation(fields: [seatEntitlementId], references: [id], onDelete: Cascade)
  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer          Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([seatEntitlementId, email])
  @@index([organizationId, status])
  @@index([customerId])
  @@map("seat_assignments")
}

model ActivationRecord {
  id                  String           @id @default(cuid())
  activationId        String           @unique
  licenseId           String
  organizationId      String?
  customerId          String?
  requestedByEmail    String
  deviceFingerprint   String
  machineName         String?
  activationTokenHash String?
  requestNonce        String?
  status              ActivationStatus @default(requested)
  requestedAt         DateTime         @default(now())
  confirmedAt         DateTime?
  lastSeenAt          DateTime?
  revokedAt           DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  license             License          @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  organization        Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  customer            Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([licenseId, status])
  @@index([organizationId])
  @@index([customerId])
  @@map("activation_records")
}
