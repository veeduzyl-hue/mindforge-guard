{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "mindforge://schemas/drift/drift_signal_bundle.v2.json",
    "title": "Drift Signal Bundle v2",
    "type": "object",
    "additionalProperties": false,
    "required": ["kind", "v", "window", "generated_at", "trend", "signal", "policy"],
    "properties": {
      "kind": { "const": "drift_signal_bundle" },
      "v": { "const": 2 },
      "window": {
        "type": "string",
        "enum": ["7d", "14d", "30d"]
      },
      "generated_at": {
        "type": "string",
         "minLength": 1
      },

      "trend": {
        "type": "string",
        "enum": ["accelerating", "stable", "cooling"]
      },
      "signal": {
        "type": "object",
        "additionalProperties": false,
        "required": ["density", "slope", "expansion", "unique_modules"],
        "properties": {
          "density": { "type": "number", "minimum": 0 },
          "slope": { "type": "number" },
          "expansion": { "type": "number", "minimum": 0 },
          "unique_modules": { "type": "number", "minimum": 0 }
        }
      },
      "highlights": {
        "type": "array",
        "maxItems": 10,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "id", "delta"],
          "properties": {
            "type": { "type": "string", "enum": ["surface", "module"] },
            "id": { "type": "string", "minLength": 1 },
            "delta": { "type": "number" }
          }
        }
      },
      "explain": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "events": { "type": "number", "minimum": 0 },
          "events_prev": { "type": "number", "minimum": 0 },
          "unique_modules_prev": { "type": "number", "minimum": 0 }
        }
      },
      "modules": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["module", "drift_units"],
          "properties": {
            "module": { "type": "string", "minLength": 1 },
            "drift_units": { "type": "number", "minimum": 0 },
            "boundary": { "type": ["string", "null"] }
          }
        }
      },
      "dominance": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metric",
          "top_n",
          "total_contribution",
          "top_modules",
          "dominance_ratio",
          "top3_share",
          "cross_boundary"
        ],
        "properties": {
          "metric": { "type": "string", "minLength": 1 },
          "top_n": { "type": "number", "minimum": 0 },
          "total_contribution": { "type": "number", "minimum": 0 },
          "top_modules": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["module", "contribution", "share", "rank"],
              "properties": {
                "module": { "type": "string", "minLength": 1 },
                "contribution": { "type": "number", "minimum": 0 },
                "share": { "type": "number", "minimum": 0, "maximum": 1 },
                "rank": { "type": "number", "minimum": 1 }
              }
            }
          },
          "dominance_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
          "top3_share": { "type": "number", "minimum": 0, "maximum": 1 },
          "cross_boundary": {
            "type": "object",
            "additionalProperties": false,
            "required": ["is_cross_boundary", "boundaries", "note"],
            "properties": {
              "is_cross_boundary": { "type": "boolean" },
              "boundaries": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["boundary", "contribution", "share"],
                  "properties": {
                    "boundary": { "type": "string", "minLength": 1 },
                    "contribution": { "type": "number", "minimum": 0 },
                    "share": { "type": "number", "minimum": 0, "maximum": 1 }
                  }
                }
              },
              "note": { "type": "string", "minLength": 1 }
            }
          }
        }
      },
      "policy": {
        "type": "object",
        "additionalProperties": false,
        "required": ["affects_exit", "affects_risk_v1"],
        "properties": {
          "affects_exit": { "const": false },
          "affects_risk_v1": { "const": false }
        }
      }
    }
  }
  
