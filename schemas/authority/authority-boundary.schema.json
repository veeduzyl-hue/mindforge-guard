{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindforge.dev/schemas/authority/authority-boundary.schema.json",
  "title": "MindForge Guard v6.14 Authority Boundary Envelope",
  "description": "Preview-only additive schema for bounded authority and intent interpretation artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "v6_14_preview",
    "recommendation_only",
    "non_executing",
    "default_off",
    "machine_verifiable",
    "no_execution_authority",
    "no_commit_gate_semantics",
    "no_license_gating_semantic_change",
    "no_current_cli_contract_change",
    "no_current_exit_code_semantic_change",
    "decision",
    "actor",
    "intent",
    "context_snapshot",
    "authority_scope",
    "authority_receipt"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v6.14-preview"
    },
    "v6_14_preview": {
      "type": "boolean",
      "const": true
    },
    "recommendation_only": {
      "type": "boolean",
      "const": true
    },
    "non_executing": {
      "type": "boolean",
      "const": true
    },
    "default_off": {
      "type": "boolean",
      "const": true
    },
    "machine_verifiable": {
      "type": "boolean",
      "const": true
    },
    "no_execution_authority": {
      "type": "boolean",
      "const": true
    },
    "no_commit_gate_semantics": {
      "type": "boolean",
      "const": true
    },
    "no_license_gating_semantic_change": {
      "type": "boolean",
      "const": true
    },
    "no_current_cli_contract_change": {
      "type": "boolean",
      "const": true
    },
    "no_current_exit_code_semantic_change": {
      "type": "boolean",
      "const": true
    },
    "decision": {
      "type": "string",
      "enum": [
        "inside_scope",
        "outside_scope",
        "needs_review",
        "insufficient_context"
      ]
    },
    "actor": {
      "$ref": "#/$defs/actor"
    },
    "intent": {
      "$ref": "#/$defs/intent"
    },
    "context_snapshot": {
      "$ref": "#/$defs/contextSnapshot"
    },
    "authority_scope": {
      "$ref": "#/$defs/authorityScope"
    },
    "authority_receipt": {
      "$ref": "#/$defs/authorityReceipt"
    }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_type",
        "display_name",
        "initiated_by"
      ],
      "properties": {
        "actor_type": {
          "type": "string",
          "enum": [
            "ai_coding_assistant",
            "human_operator",
            "local_tool"
          ]
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "initiated_by": {
          "type": "string",
          "enum": [
            "user_request",
            "local_invocation",
            "documented_plan"
          ]
        }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "change_kind",
        "target_paths",
        "protected_surfaces_touched"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "change_kind": {
          "type": "string",
          "enum": [
            "docs_only",
            "schema_and_fixture_only",
            "runtime_adjacent",
            "commercial_surface_change"
          ]
        },
        "target_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "protected_surfaces_touched": {
          "type": "boolean"
        }
      }
    },
    "contextSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "branch",
        "current_release_line",
        "protected_surface_paths",
        "protected_surfaces_touched"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "const": "mindforge-guard"
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "current_release_line": {
          "type": "string",
          "const": "v6.13.1"
        },
        "protected_surface_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "protected_surfaces_touched": {
          "type": "boolean"
        }
      }
    },
    "authorityScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_operation",
        "boundary_summary",
        "execution_authority_granted",
        "blocking_implied"
      ],
      "properties": {
        "requested_operation": {
          "type": "string",
          "enum": [
            "plan_docs_only",
            "define_schema_fixture_boundary",
            "touch_protected_surface",
            "runtime_or_deploy_change"
          ]
        },
        "boundary_summary": {
          "type": "string",
          "minLength": 1
        },
        "execution_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "blocking_implied": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "authorityReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_id",
        "summary",
        "recommendation_only",
        "non_executing",
        "default_off",
        "machine_verifiable",
        "execution_authority_granted",
        "enforcement_action",
        "blocking_effect",
        "recommended_next_step"
      ],
      "properties": {
        "receipt_id": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "recommendation_only": {
          "type": "boolean",
          "const": true
        },
        "non_executing": {
          "type": "boolean",
          "const": true
        },
        "default_off": {
          "type": "boolean",
          "const": true
        },
        "machine_verifiable": {
          "type": "boolean",
          "const": true
        },
        "execution_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "enforcement_action": {
          "type": "string",
          "const": "none"
        },
        "blocking_effect": {
          "type": "boolean",
          "const": false
        },
        "recommended_next_step": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
