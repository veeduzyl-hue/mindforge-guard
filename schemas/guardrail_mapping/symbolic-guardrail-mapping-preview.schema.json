{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindforge.dev/schemas/guardrail_mapping/symbolic-guardrail-mapping-preview.schema.json",
  "title": "MindForge Guard v6.19 Symbolic Guardrail Mapping Preview Boundary",
  "description": "Preview-only additive schema for fixture-backed symbolic guardrail mapping artifacts. Mapping only, not enforcement.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "preview",
    "mapping_only",
    "enforcement_action",
    "blocking_effect",
    "execution_authority_granted",
    "input_ref",
    "input_summary",
    "requirements",
    "mappings",
    "unmapped_requirements",
    "non_enforcement_boundary",
    "deterministic_hash"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "guard.symbolic_guardrail_mapping.v1"
    },
    "preview": {
      "type": "boolean",
      "const": true
    },
    "mapping_only": {
      "type": "boolean",
      "const": true
    },
    "recommendation_only": {
      "type": "boolean",
      "const": true
    },
    "non_executing": {
      "type": "boolean",
      "const": true
    },
    "additive_only": {
      "type": "boolean",
      "const": true
    },
    "enforcement_action": {
      "type": "string",
      "const": "none"
    },
    "blocking_effect": {
      "type": "boolean",
      "const": false
    },
    "execution_authority_granted": {
      "type": "boolean",
      "const": false
    },
    "input_ref": {
      "$ref": "#/$defs/inputRef"
    },
    "input_summary": {
      "$ref": "#/$defs/inputSummary"
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/requirement"
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/mapping"
      }
    },
    "unmapped_requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unmappedRequirement"
      }
    },
    "non_enforcement_boundary": {
      "$ref": "#/$defs/nonEnforcementBoundary"
    },
    "deterministic_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "$defs": {
    "guardrailType": {
      "type": "string",
      "enum": [
        "schema_constraint",
        "api_validation",
        "state_check",
        "evidence_check",
        "capability_check",
        "context_check",
        "confirmation_required"
      ]
    },
    "mappingStatus": {
      "type": "string",
      "enum": [
        "mapped",
        "partially_mapped",
        "unmapped",
        "out_of_scope",
        "unknown"
      ]
    },
    "verificationSurface": {
      "type": "string",
      "enum": [
        "fixture_declared",
        "schema_declared",
        "external_system_required",
        "human_review_required",
        "not_symbolically_mappable"
      ]
    },
    "inputRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "fixture_file",
        "fixture_schema_version",
        "fixture_backed"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "fixture_file"
        },
        "fixture_file": {
          "type": "string",
          "minLength": 1
        },
        "fixture_schema_version": {
          "type": "string",
          "minLength": 1
        },
        "fixture_backed": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "inputSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_count",
        "requirement_count",
        "mapping_status_counts",
        "fixture_backed",
        "no_live_repo_state_reading",
        "no_live_source_fetching",
        "no_external_calls"
      ],
      "properties": {
        "case_count": {
          "type": "integer",
          "minimum": 1
        },
        "requirement_count": {
          "type": "integer",
          "minimum": 1
        },
        "mapping_status_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mapped",
            "partially_mapped",
            "unmapped",
            "out_of_scope",
            "unknown"
          ],
          "properties": {
            "mapped": { "type": "integer", "minimum": 0 },
            "partially_mapped": { "type": "integer", "minimum": 0 },
            "unmapped": { "type": "integer", "minimum": 0 },
            "out_of_scope": { "type": "integer", "minimum": 0 },
            "unknown": { "type": "integer", "minimum": 0 }
          }
        },
        "fixture_backed": {
          "type": "boolean",
          "const": true
        },
        "no_live_repo_state_reading": {
          "type": "boolean",
          "const": true
        },
        "no_live_source_fetching": {
          "type": "boolean",
          "const": true
        },
        "no_external_calls": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "requirement_id",
        "requirement_text",
        "guardrail_type"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "requirement_id": {
          "type": "string",
          "minLength": 1
        },
        "requirement_text": {
          "type": "string",
          "minLength": 1
        },
        "guardrail_type": {
          "$ref": "#/$defs/guardrailType"
        }
      }
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "requirement_id",
        "guardrail_type",
        "mapping_status",
        "verification_surface",
        "symbolic_surfaces",
        "mapping_explanation",
        "coverage_gap_summary"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "requirement_id": {
          "type": "string",
          "minLength": 1
        },
        "guardrail_type": {
          "$ref": "#/$defs/guardrailType"
        },
        "mapping_status": {
          "$ref": "#/$defs/mappingStatus"
        },
        "verification_surface": {
          "$ref": "#/$defs/verificationSurface"
        },
        "symbolic_surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "mapping_explanation": {
          "type": "string",
          "minLength": 1
        },
        "coverage_gap_summary": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "unmappedRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "requirement_text",
        "verification_surface",
        "mapping_explanation"
      ],
      "properties": {
        "requirement_id": {
          "type": "string",
          "minLength": 1
        },
        "requirement_text": {
          "type": "string",
          "minLength": 1
        },
        "verification_surface": {
          "$ref": "#/$defs/verificationSurface"
        },
        "mapping_explanation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "nonEnforcementBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mapping_only",
        "enforcement_action",
        "blocking_effect",
        "execution_authority_granted",
        "does_not_evaluate_guardrail_result",
        "does_not_create_policy_engine",
        "does_not_create_commit_gate",
        "does_not_create_permit_gate",
        "does_not_create_deployment_gate"
      ],
      "properties": {
        "mapping_only": {
          "type": "boolean",
          "const": true
        },
        "enforcement_action": {
          "type": "string",
          "const": "none"
        },
        "blocking_effect": {
          "type": "boolean",
          "const": false
        },
        "execution_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "does_not_evaluate_guardrail_result": {
          "type": "boolean",
          "const": true
        },
        "does_not_create_policy_engine": {
          "type": "boolean",
          "const": true
        },
        "does_not_create_commit_gate": {
          "type": "boolean",
          "const": true
        },
        "does_not_create_permit_gate": {
          "type": "boolean",
          "const": true
        },
        "does_not_create_deployment_gate": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
