{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindforge.dev/schemas/single_agent_governance_pack_preview/v1/action-boundary.schema.json",
  "title": "MindForge Guard v7.0 Single-Agent Governance Pack Preview Action Boundary",
  "description": "Preview-only action boundary schema candidate for the single-agent governance evidence pack.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "allowed_actions",
    "prohibited_actions",
    "human_review_required",
    "escalation_required",
    "external_side_effects"
  ],
  "properties": {
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prohibited_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "human_review_required": {
      "type": "boolean"
    },
    "escalation_required": {
      "type": "boolean"
    },
    "external_side_effects": {
      "type": "string",
      "enum": [
        "none",
        "limited",
        "present"
      ]
    }
  }
}
