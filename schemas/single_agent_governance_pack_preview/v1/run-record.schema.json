{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindforge.dev/schemas/single_agent_governance_pack_preview/v1/run-record.schema.json",
  "title": "MindForge Guard v7.0 Single-Agent Governance Pack Preview Run Record",
  "description": "Preview-only run record schema candidate for the single-agent governance evidence pack.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "run_timestamp",
    "environment",
    "input_ref",
    "output_ref",
    "tool_calls_summary",
    "errors_or_warnings",
    "reviewer_observation"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_timestamp": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "enum": [
        "local_preview",
        "ci_preview"
      ]
    },
    "input_ref": {
      "type": "string",
      "minLength": 1
    },
    "output_ref": {
      "type": "string",
      "minLength": 1
    },
    "tool_calls_summary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "errors_or_warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reviewer_observation": {
      "type": "string",
      "minLength": 1
    }
  }
}
