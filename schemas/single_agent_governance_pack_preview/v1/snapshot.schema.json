{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindforge.dev/schemas/single_agent_governance_pack_preview/v1/snapshot.schema.json",
  "title": "MindForge Guard v7.0 Single-Agent Governance Pack Preview Snapshot",
  "description": "Preview-only snapshot schema candidate for the single-agent governance evidence pack.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshot_id",
    "version",
    "commit_sha",
    "environment",
    "generated_at",
    "artifact_hashes",
    "comparison_baseline"
  ],
  "properties": {
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$"
    },
    "environment": {
      "type": "string",
      "enum": [
        "local_preview",
        "ci_preview"
      ]
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "artifact_hashes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^sha256:[a-f0-9]{64}$"
      }
    },
    "comparison_baseline": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
