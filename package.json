{
    "name": "mindforge-guard-workspace",
    "private": true,
    "packageManager": "npm@11.9.0",
    "workspaces": ["packages/*", "apps/*"],
    "engines": { "node": ">=18" },
    "scripts": {
      "install:all": "npm install",
      "guard": "node packages/guard/src/runGuard.mjs",
      "guard:help": "node packages/guard/src/runGuard.mjs --help",
      "guard:version": "node packages/guard/src/runGuard.mjs --version",
      "license-hub:dev": "npm --workspace @mindforge/license-hub run dev",
      "db:generate": "npm --workspace @mindforge/db run generate",
      "db:migrate:dev": "npm --workspace @mindforge/db run migrate:dev",
      "verify:core": "node scripts/verify_governance_surface.mjs && node scripts/verify_governance_consumption_profile.mjs && node scripts/verify_audit_permit_gate.mjs",
      "verify:v612": "node scripts/verify_governance_case_review_decision_closure_evidence_package_delivery_manifest_acceptance_semantics_boundary.mjs && node scripts/verify_governance_case_review_decision_closure_evidence_package_delivery_manifest_acceptance_semantics_hardening.mjs && node scripts/verify_governance_case_review_decision_closure_evidence_package_delivery_manifest_acceptance_semantics_final_acceptance.mjs",
      "verify:phase6-seats-account-activation": "node scripts/verify_phase6_seats_account_activation_boundary.mjs",
      "verify:phase6-5-commercial-packaging": "node scripts/verify_phase6_5_commercial_packaging_boundary.mjs",
      "verify:guard-cli-activation-ux-phase5": "node scripts/verify_guard_cli_activation_ux_phase5.mjs",
      "verify:license-hub-license-validity-semantics": "node scripts/verify_license_hub_license_validity_semantics.mjs",
      "verify:license-hub-ops-baseline": "node scripts/verify_license_hub_ops_baseline.mjs",
      "verify:license-hub-phase4": "node scripts/verify_license_hub_phase4_payment_lifecycle_boundary.mjs",
      "verify:license-hub-phase3": "node scripts/verify_license_hub_phase3_admin_boundary.mjs",
      "verify:license-hub-phase2": "node scripts/verify_license_hub_phase2_boundary.mjs",
      "verify:license-hub-skeleton": "node scripts/verify_license_hub_skeleton_phase1.mjs",
      "verify:ramen:v5:local-spike": "node scripts/verify_ramen_receipt_v5_local_spike.mjs",
      "verify:external-evidence:type-contract": "node scripts/verify_external_evidence_type_contract.mjs",
      "verify:harness-phase2:evidence": "node scripts/verify_harness_phase2_external_evidence_schema.mjs",
      "verify:harness-phase2:normalizer": "node scripts/verify_harness_phase2_pack_normalizer_renderer.mjs",
      "verify:harness-phase2:contract": "node scripts/verify_harness_phase2_evidence_type_contract_hardening.mjs",
      "verify:harness-phase2:snapshots": "node scripts/verify_harness_phase2_review_report_snapshots.mjs",
      "verify:harness-phase2:reviewer-packet": "node scripts/verify_harness_phase2_reviewer_packet.mjs",
      "verify:outcome-foundation": "node scripts/verify_outcome_foundation_contract.mjs",
      "verify:outcome-foundation:negative": "node scripts/verify_outcome_foundation_negative_contract.mjs",
      "verify": "npm run verify:core && npm run verify:v612 && npm run verify:external-evidence:type-contract"
    }
  }
