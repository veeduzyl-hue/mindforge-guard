{
    "name": "mindforge-guard-workspace",
    "lockfileVersion": 3,
    "requires": true,
    "packages": {
        "": {
            "name": "mindforge-guard-workspace",
            "workspaces": [
                "packages/*"
            ],
            "engines": {
                "node": ">=18"
            }
        },
        "node_modules/@veeduzyl/mindforge-guard": {
            "resolved": "packages/guard",
            "link": true
        },
        "node_modules/@veeduzyl/mindforge-kernel": {
            "resolved": "packages/kernel",
            "link": true
        },
        "packages/guard": {
            "name": "@veeduzyl/mindforge-guard",
            "version": "1.0.1",
            "bin": {
                "guard": "bin/guard.mjs"
            }
        },
        "packages/kernel": {
            "name": "@veeduzyl/mindforge-kernel",
            "version": "0.20.0"
        }
    }
}
