LICENSE_HUB_ADMIN_EMAILS="admin@example.com"
LICENSE_HUB_BASE_URL="http://localhost:3000"
LICENSE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"
LICENSE_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"
LICENSE_KEY_ID="mf_k1_2026"
LICENSE_ISSUER_NAME="MindForge Licensing Authority"
MAGIC_LINK_MAIL_MODE="dev"
ALLOW_DEV_MAGIC_LINK_IN_PRODUCTION="false"
MAGIC_LINK_DEBUG_STORE_PATH="../../.mindforge/license-hub/magic-links.jsonl"
BILLING_PROVIDER="billing_provider"
BILLING_WEBHOOK_SECRET="replace-with-billing-webhook-secret"
BILLING_SIGNATURE_HEADER="x-billing-signature"
BILLING_ALLOW_UNSIGNED_DEV="true"
PADDLE_ENV="sandbox"
PADDLE_API_KEY=""
PADDLE_CLIENT_TOKEN=""
