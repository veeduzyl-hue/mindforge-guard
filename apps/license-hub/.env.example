PADDLE_CHECKOUT_SUCCESS_URL="http://localhost:3000/paddle/success"
PADDLE_CHECKOUT_CANCEL_URL="http://localhost:3000/paddle/cancel"
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

